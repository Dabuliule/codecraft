#!/usr/bin/env bash
set -euo pipefail

regex='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._/-]+\))?!?: .+'
invalid=0

while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "${local_sha}" = "0000000000000000000000000000000000000000" ]; then
    continue
  fi

  if [ "${remote_sha}" = "0000000000000000000000000000000000000000" ]; then
    commits="$(git rev-list --no-merges "${local_sha}" --not --remotes)"
  else
    commits="$(git rev-list --no-merges "${remote_sha}..${local_sha}")"
  fi

  for commit in ${commits}; do
    subject="$(git log -1 --pretty=%s "${commit}")"
    if ! [[ "${subject}" =~ ${regex} ]]; then
      echo "Rejected by pre-push hook (non-Conventional Commit): ${subject}"
      invalid=1
    fi
  done
done

if [ "${invalid}" -ne 0 ]; then
  echo "Push blocked: commit messages must follow Conventional Commits."
  exit 1
fi
